#!/usr/bin/env bash
# shellcheck disable=SC2034  # variables are consumed by setup.sh

########################################
# GIMP Setup configuration
#
# Copy this file to config.sh and fill in
# your values. config.sh is gitignored.
#
# Every value falls back to an environment
# variable of the same name, so a parent
# script (for example, linux-mint-setup)
# can export these instead of shipping a
# config.sh.
########################################

#
# Google Gemini API key, shared by the AI plug-ins
# (Filters > AI > Remove Selection / Generative Fill / Image Generator
# with the Gemini provider).
#
# Get a free key at https://aistudio.google.com/apikey
#
# Leave empty to configure the backend later. The setup saves it to
# ~/.config/PhotoGIMP/gemini-api-key (host and Flatpak sandbox copies).
#
GEMINI_API_KEY="${GEMINI_API_KEY:-}"

#
# OpenAI API key used by the GIMP AI Plugin
# (Filters > AI > Generative Fill / Image Generator / Layer Composite
# with the OpenAI provider — paid, from platform.openai.com/api-keys).
#
# Leave empty to configure it later. The setup saves it to
# ~/.config/PhotoGIMP/openai-api-key (host and Flatpak sandbox copies);
# a key set in GIMP via Filters > AI > Settings takes precedence.
#
OPENAI_API_KEY="${OPENAI_API_KEY:-}"
